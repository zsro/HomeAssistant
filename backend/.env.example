PORT=3001
JWT_SECRET=your-secret-key-change-in-production
NODE_ENV=development

# 数据库配置
# 设置为 true 使用 MySQL 数据库，false 使用内存数据库
USE_REAL_DB=false

# MySQL 数据库配置（当 USE_REAL_DB=true 时生效）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=homeAssistantDB
DB_USER=homeAssistantUser
DB_PASSWORD=your-password

# AI 配置
# 支持的供应商: volcano, openai, claude, deepseek, mock
AI_PROVIDER=mock
AI_API_KEY=your-api-key
AI_MODEL=deepseek-v3-2-251201
# AI_BASE_URL=可选，用于代理或第三方兼容服务
